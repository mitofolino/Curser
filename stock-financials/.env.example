# Local output folder (all downloads and portfolio_summary.xlsx)
OUTPUT_DIR=/Users/mitjarebec/Documents/Stocks_Analyses

# Ticker list workbook (one symbol per row)
STOCKS_XLSX=/Users/mitjarebec/Documents/Stocks_Analyses/Stocks.xlsx

# Column with tickers (0 = A, 1 = B, …)
TICKER_COLUMN=0

# First data row (0 = first row; use 1 if row 0 is a header)
DATA_START_ROW=1

# Sheet tab name (leave empty for first sheet)
# STOCKS_SHEET=Stocks

DOWNLOAD_10K=true
STATEMENT_YEARS=5
SEC_FILINGS_LIMIT=5
SEC_EMAIL=mitofolino@gmail.com
DOWNLOAD_QUARTERLY=true

# Optional: Financial Modeling Prep API key (backup quarterly for non-US)
# FMP_API_KEY=QpaIccoaLD7jhd6MDQN250UYYqqAvEkw

# Portfolio summary: numbers (Apple Numbers), xlsx, or both
PORTFOLIO_OUTPUT=numbers
PORTFOLIO_NUMBERS_PATH=/Users/mitjarebec/Documents/Stocks_Analyses/portfolio_summary.numbers
PORTFOLIO_SHEET_NAME=portfolio
# Row 1 = headers in Numbers; position data written from this row (default 2)
PORTFOLIO_DATA_START_ROW=2

# eToro Public API (Settings → Trading → API Key Management)
# x-api-key = public key, x-user-key = user/private key from eToro
ETORO_ENABLED=true
ETORO_API_URL=https://public-api.etoro.com/api/v1
ETORO_API_PUBLIC_KEY=your_public_api_key
ETORO_API_PRIVATE_KEY=your_user_key_from_etoro
# ETORO_CSV_PATH=/path/to/etoro_positions.csv

# IBKR Client Portal (run IB Gateway / Client Portal on localhost:5000)
IBKR_ENABLED=false
# IBKR_CPAPI_URL=https://localhost:5000/v1/api
# IBKR_ACCOUNT_ID=
# IBKR_VERIFY_SSL=false
# IBKR_CSV_PATH=/path/to/ibkr_positions.csv
