# Column with tickers (0 = A, 1 = B, …)
TICKER_COLUMN=0

# First data row (0 = first row; use 1 if row 0 is a header)
DATA_START_ROW=1

# Sheet tab name (leave empty for first sheet)
# STOCKS_SHEET=Stocks

DOWNLOAD_10K=true
SEC_FILINGS_LIMIT=2
STATEMENT_YEARS=2
SEC_EMAIL=mitofolino@gmail.com
DOWNLOAD_QUARTERLY=true

